## Phase 3: Target Repo Adoption (per-repo, example)

### 3a. Release workflow: enable ci_ready

```yaml
jobs:
  release:
    uses: getsentry/craft/.github/workflows/release.yml@v2
    with:
      ci_ready: 'true'
```

### 3b. CI workflow: add signal-ready job

```yaml
jobs:
  test: ...
  build: ...

  signal-ci-ready:
    needs: [test, build] # all required CI jobs
    if: success() && startsWith(github.ref_name, 'release/')
    runs-on: ubuntu-latest
    steps:
      - name: Get auth token
        id: token
        uses: actions/create-github-app-token@v3
        with:
          app-id: ${{ vars.SENTRY_RELEASE_BOT_CLIENT_ID }}
          private-key: ${{ secrets.SENTRY_RELEASE_BOT_PRIVATE_KEY }}
          owner: getsentry
          repositories: publish

      - name: Extract version
        id: version
        run: echo "version=${GITHUB_REF_NAME#release/}" >> "$GITHUB_OUTPUT"

      - name: Signal CI ready
        uses: getsentry/craft/signal-ready@v2
        env:
          GH_TOKEN: ${{ steps.token.outputs.token }}
        with:
          version: ${{ steps.version.outputs.version }}
          sha: ${{ github.sha }}
```

